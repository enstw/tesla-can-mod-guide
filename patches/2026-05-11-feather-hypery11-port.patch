diff --git a/include/handlers_hypery11.h b/include/handlers_hypery11.h
new file mode 100644
index 0000000..1f71bfd
--- /dev/null
+++ b/include/handlers_hypery11.h
@@ -0,0 +1,215 @@
+#pragma once
+
+#include "can_frame_types.h"
+#include "drivers/can_driver.h"
+#include "handlers.h"
+
+// FeatherHypery11Handler — hypery11-derived Goal A nag suppression for the
+// Feather RP2040 CAN target. Behavior is ported from
+// flipper-tesla-fsd/fsd_logic/fsd_handler.c (fsd_handle_nag_killer plus
+// fsd_handle_gtw_car_state and fsd_handle_das_status).
+//
+// Listen-only op mode is taken from CanDriver::mode() so it cannot drift out
+// of sync with the hardware state; the handler does not own a duplicate field.
+struct FeatherHypery11Handler : public CarManagerBase
+{
+    // Runtime toggles.
+    Shared<bool> nagKillerActive{true};
+    Shared<bool> dasGate{true};
+    Shared<bool> organicTorque{true};
+
+    // Observed bus state.
+    Shared<bool> otaInProgress{false};
+    Shared<uint8_t> dasApState{0};
+    // 0xFF means no 0x39B frame seen yet — echo conservatively as fallback.
+    Shared<uint8_t> dasHandsOnState{0xFF};
+    Shared<bool> dasSeen{false};
+
+    // Counters / diagnostics.
+    Shared<uint32_t> nagEchoCount{0};
+    Shared<uint32_t> nagBlockedListenOnly{0};
+    Shared<uint32_t> nagBlockedOta{0};
+    Shared<uint32_t> epasSeenCount{0};
+
+    static constexpr uint32_t kIdEpasStatus = 0x370;   // 880
+    static constexpr uint32_t kIdGtwCarState = 0x318;  // 792
+    static constexpr uint32_t kIdDasStatus = 0x39B;    // 923
+
+    // Torque raw encoding: rawTorque = (Nm + 20.5) / 0.01
+    // Normal walk band ≈ [1.00, 2.40] Nm, grip pulse ≈ [3.10, 3.30] Nm.
+    static constexpr int16_t kTorqueWalkMin = 2150;    // 1.00 Nm
+    static constexpr int16_t kTorqueWalkMax = 2290;    // 2.40 Nm
+    static constexpr int16_t kTorquePulseMin = 2330;   // 2.80 Nm
+    static constexpr int16_t kTorquePulseMax = 2370;   // 3.20 Nm
+    static constexpr int16_t kTorqueFixed = 2230;      // 1.80 Nm fallback
+
+    const uint32_t *filterIds() const override
+    {
+        static constexpr uint32_t ids[] = {kIdEpasStatus, kIdGtwCarState, kIdDasStatus};
+        return ids;
+    }
+    uint8_t filterIdCount() const override { return 3; }
+
+    void handleMessage(CanFrame &frame, CanDriver &driver) override
+    {
+        if (onFrame)
+            onFrame(frame);
+
+        if (frame.id == kIdGtwCarState)
+        {
+            parseGtwCarState(frame);
+            return;
+        }
+        if (frame.id == kIdDasStatus)
+        {
+            parseDasStatus(frame);
+            return;
+        }
+        if (frame.id == kIdEpasStatus)
+        {
+            epasSeenCount++;
+            handleEpas(frame, driver);
+        }
+    }
+
+    void parseGtwCarState(const CanFrame &frame)
+    {
+        if (frame.dlc < 7)
+            return;
+        // GTW_updateInProgress: byte 6 bits 1:0.
+        // Raw values: 0=No update, 1=Available, 2=Installing, 3=Scheduled.
+        // Only raw 2 must block TX (issue #19 documents false positives on 1).
+        uint8_t raw = frame.data[6] & 0x03;
+        otaInProgress = (raw == 2);
+    }
+
+    void parseDasStatus(const CanFrame &frame)
+    {
+        if (frame.dlc < 7)
+            return;
+        dasApState = (frame.data[1] >> 4) & 0x0F;
+        dasHandsOnState = (frame.data[5] >> 2) & 0x0F;
+        dasSeen = true;
+    }
+
+    void seedPrng(uint32_t s)
+    {
+        prngState_ = s ? s : 0xDEADBEEFu;
+        torqueWalk_ = kTorqueFixed;
+        pulseFramesLeft_ = 0;
+        framesUntilPulse_ = 175;
+    }
+
+private:
+    uint32_t prngState_ = 0xDEADBEEFu;
+    int16_t torqueWalk_ = kTorqueFixed;
+    uint8_t pulseFramesLeft_ = 0;
+    uint16_t framesUntilPulse_ = 175;
+
+    uint32_t xorshift32()
+    {
+        uint32_t x = prngState_;
+        x ^= x << 13;
+        x ^= x >> 17;
+        x ^= x << 5;
+        prngState_ = x;
+        return x;
+    }
+
+    void handleEpas(const CanFrame &frame, CanDriver &driver)
+    {
+        if (frame.dlc < 8)
+            return;
+        if (!nagKillerActive)
+            return;
+        if (driver.mode() == CanMode::ListenOnly)
+        {
+            nagBlockedListenOnly++;
+            return;
+        }
+        if (otaInProgress)
+        {
+            nagBlockedOta++;
+            return;
+        }
+
+        // EPAS handsOnLevel — skip only on level 1 (hands detected).
+        // Echo on 0 (nag imminent), 2 (warn), 3 (escalated alarm).
+        uint8_t handsOn = (frame.data[4] >> 6) & 0x03;
+        if (handsOn == 1)
+            return;
+
+        if (dasGate)
+        {
+            uint8_t das = dasHandsOnState;
+            // 0 = NOT_REQD, 8 = SUSPENDED. Both mean DAS is satisfied.
+            // 0xFF (unseen) falls through and echoes conservatively.
+            if (das == 0 || das == 8)
+                return;
+        }
+
+        CanFrame echo;
+        echo.id = kIdEpasStatus;
+        echo.dlc = 8;
+        echo.bus = frame.bus;
+
+        echo.data[0] = frame.data[0];
+        echo.data[1] = frame.data[1];
+
+        int16_t torq = nextTorqueRaw();
+        echo.data[2] = (frame.data[2] & 0xF0) | static_cast<uint8_t>((torq >> 8) & 0x0F);
+        echo.data[3] = static_cast<uint8_t>(torq & 0xFF);
+
+        // Clear handsOnLevel bits 7:6 before setting level=1.
+        echo.data[4] = (frame.data[4] & ~0xC0u) | 0x40u;
+        echo.data[5] = frame.data[5];
+
+        uint8_t cnt = (frame.data[6] & 0x0F);
+        cnt = (cnt + 1) & 0x0F;
+        echo.data[6] = (frame.data[6] & 0xF0) | cnt;
+
+        uint16_t sum = 0;
+        for (int i = 0; i < 7; i++)
+            sum += echo.data[i];
+        sum += (kIdEpasStatus & 0xFF) + ((kIdEpasStatus >> 8) & 0xFF);
+        echo.data[7] = static_cast<uint8_t>(sum & 0xFF);
+
+        framesSent++;
+        nagEchoCount++;
+        driver.send(echo);
+    }
+
+    int16_t nextTorqueRaw()
+    {
+        if (!organicTorque)
+            return kTorqueFixed;
+
+        if (pulseFramesLeft_ > 0)
+        {
+            int16_t pulse = 2350 + static_cast<int16_t>((xorshift32() % 41) - 20);
+            pulseFramesLeft_--;
+            return pulse;
+        }
+
+        int16_t step = static_cast<int16_t>((xorshift32() % 31) - 15);
+        torqueWalk_ += step;
+        if (torqueWalk_ < kTorqueWalkMin)
+            torqueWalk_ = kTorqueWalkMin;
+        if (torqueWalk_ > kTorqueWalkMax)
+            torqueWalk_ = kTorqueWalkMax;
+
+        if (framesUntilPulse_ > 0)
+        {
+            framesUntilPulse_--;
+        }
+        else
+        {
+            // Pulse lasts 3-5 frames, with 125-224 frames (~5-9 s at 25 Hz)
+            // between pulses.
+            pulseFramesLeft_ = 3 + static_cast<uint8_t>(xorshift32() % 3);
+            framesUntilPulse_ = 125 + static_cast<uint16_t>(xorshift32() % 100);
+        }
+
+        return torqueWalk_;
+    }
+};
