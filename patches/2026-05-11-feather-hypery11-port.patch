diff --git a/test/test_native_can_mode/test_can_mode.cpp b/test/test_native_can_mode/test_can_mode.cpp
new file mode 100644
index 0000000..0d9718e
--- /dev/null
+++ b/test/test_native_can_mode/test_can_mode.cpp
@@ -0,0 +1,175 @@
+#include <unity.h>
+#include "can_frame_types.h"
+#include "drivers/can_driver.h"
+#include "drivers/mock_driver.h"
+
+static MockDriver mock;
+
+static CanFrame makeFrame(uint32_t id = 0x370)
+{
+    CanFrame f = {.id = id, .dlc = 8};
+    for (int i = 0; i < 8; i++)
+        f.data[i] = static_cast<uint8_t>(i + 1);
+    return f;
+}
+
+void setUp() { mock.reset(); }
+void tearDown() {}
+
+void test_default_mode_is_normal()
+{
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::Normal),
+                      static_cast<int>(mock.mode()));
+}
+
+void test_set_mode_listen_only_persists()
+{
+    mock.setMode(CanMode::ListenOnly);
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::ListenOnly),
+                      static_cast<int>(mock.mode()));
+}
+
+void test_set_mode_back_to_normal_persists()
+{
+    mock.setMode(CanMode::ListenOnly);
+    mock.setMode(CanMode::Normal);
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::Normal),
+                      static_cast<int>(mock.mode()));
+}
+
+void test_send_succeeds_in_normal_mode()
+{
+    CanFrame f = makeFrame();
+    bool ok = mock.send(f);
+    TEST_ASSERT_TRUE(ok);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    TEST_ASSERT_EQUAL(0, mock.blocked.size());
+}
+
+void test_send_blocked_in_listen_only_mode()
+{
+    mock.setMode(CanMode::ListenOnly);
+    CanFrame f = makeFrame();
+    bool ok = mock.send(f);
+    TEST_ASSERT_FALSE(ok);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL(1, mock.blocked.size());
+    TEST_ASSERT_EQUAL_UINT32(0x370, mock.blocked[0].id);
+}
+
+void test_multiple_sends_all_blocked_in_listen_only()
+{
+    mock.setMode(CanMode::ListenOnly);
+    for (int i = 0; i < 5; i++)
+        mock.send(makeFrame(0x100 + i));
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL(5, mock.blocked.size());
+}
+
+void test_switching_from_listen_only_to_normal_allows_send()
+{
+    mock.setMode(CanMode::ListenOnly);
+    mock.send(makeFrame(0x111));
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL(1, mock.blocked.size());
+
+    mock.setMode(CanMode::Normal);
+    bool ok = mock.send(makeFrame(0x222));
+    TEST_ASSERT_TRUE(ok);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    TEST_ASSERT_EQUAL(1, mock.blocked.size()); // prior block stays recorded
+}
+
+void test_set_filters_preserves_listen_only_mode()
+{
+    mock.setMode(CanMode::ListenOnly);
+    const uint32_t ids[] = {0x370, 0x39B, 0x318};
+    mock.setFilters(ids, 3);
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::ListenOnly),
+                      static_cast<int>(mock.mode()));
+    TEST_ASSERT_EQUAL_UINT32(1, mock.setFiltersCalls);
+
+    // Sends after setFilters must still be blocked.
+    mock.send(makeFrame());
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL(1, mock.blocked.size());
+}
+
+void test_set_filters_preserves_normal_mode()
+{
+    // Sanity: Normal stays Normal across setFilters.
+    const uint32_t ids[] = {0x370};
+    mock.setFilters(ids, 1);
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::Normal),
+                      static_cast<int>(mock.mode()));
+    bool ok = mock.send(makeFrame());
+    TEST_ASSERT_TRUE(ok);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+}
+
+void test_repeated_set_filters_does_not_drop_listen_only()
+{
+    mock.setMode(CanMode::ListenOnly);
+    const uint32_t ids[] = {0x370};
+    for (int i = 0; i < 3; i++)
+        mock.setFilters(ids, 1);
+    TEST_ASSERT_EQUAL_UINT32(3, mock.setFiltersCalls);
+    TEST_ASSERT_EQUAL(static_cast<int>(CanMode::ListenOnly),
+                      static_cast<int>(mock.mode()));
+}
+
+// onSendFrame callback contract: ListenOnly fires the callback with ok=false
+// so callers see the blocked attempt without the driver silently dropping it.
+static int g_callbackCount = 0;
+static bool g_lastOk = true;
+static void recordCallback(const CanFrame & /*f*/, bool ok)
+{
+    g_callbackCount++;
+    g_lastOk = ok;
+}
+
+void test_listen_only_callback_reports_failure()
+{
+    g_callbackCount = 0;
+    g_lastOk = true;
+    mock.onSendFrame = recordCallback;
+    mock.setMode(CanMode::ListenOnly);
+    mock.send(makeFrame());
+    TEST_ASSERT_EQUAL(1, g_callbackCount);
+    TEST_ASSERT_FALSE(g_lastOk);
+    mock.onSendFrame = nullptr;
+}
+
+void test_normal_callback_reports_success()
+{
+    g_callbackCount = 0;
+    g_lastOk = false;
+    mock.onSendFrame = recordCallback;
+    mock.send(makeFrame());
+    TEST_ASSERT_EQUAL(1, g_callbackCount);
+    TEST_ASSERT_TRUE(g_lastOk);
+    mock.onSendFrame = nullptr;
+}
+
+int main()
+{
+    UNITY_BEGIN();
+
+    RUN_TEST(test_default_mode_is_normal);
+    RUN_TEST(test_set_mode_listen_only_persists);
+    RUN_TEST(test_set_mode_back_to_normal_persists);
+
+    RUN_TEST(test_send_succeeds_in_normal_mode);
+    RUN_TEST(test_send_blocked_in_listen_only_mode);
+    RUN_TEST(test_multiple_sends_all_blocked_in_listen_only);
+    RUN_TEST(test_switching_from_listen_only_to_normal_allows_send);
+
+    RUN_TEST(test_set_filters_preserves_listen_only_mode);
+    RUN_TEST(test_set_filters_preserves_normal_mode);
+    RUN_TEST(test_repeated_set_filters_does_not_drop_listen_only);
+
+    RUN_TEST(test_listen_only_callback_reports_failure);
+    RUN_TEST(test_normal_callback_reports_success);
+
+    return UNITY_END();
+}
diff --git a/test/test_native_hypery11/test_hypery11_handler.cpp b/test/test_native_hypery11/test_hypery11_handler.cpp
new file mode 100644
index 0000000..ba3cddf
--- /dev/null
+++ b/test/test_native_hypery11/test_hypery11_handler.cpp
@@ -0,0 +1,504 @@
+#include <unity.h>
+#include "can_frame_types.h"
+#include "drivers/can_driver.h"
+#include "drivers/mock_driver.h"
+#include "handlers_hypery11.h"
+
+static MockDriver mock;
+static FeatherHypery11Handler handler;
+
+// --- Frame builders -----------------------------------------------------
+
+// 0x370 EPAS3P_sysStatus stub with controllable handsOnLevel + counter.
+// Checksum is recomputed so input frames are self-consistent (handler does
+// not verify input checksum, but real-bus frames will be valid).
+static CanFrame makeEpasFrame(uint8_t handsOn, uint8_t counter)
+{
+    CanFrame f = {.id = 0x370, .dlc = 8};
+    f.data[0] = 0x12;
+    f.data[1] = 0x00;
+    f.data[2] = 0x08; // upper nibble = flags, lower will get torque hi
+    f.data[3] = 0xB6; // dummy torque
+    f.data[4] = static_cast<uint8_t>(((handsOn & 0x03) << 6) | 0x1F);
+    f.data[5] = 0x89;
+    f.data[6] = static_cast<uint8_t>((0x20) | (counter & 0x0F));
+    uint16_t sum = 0;
+    for (int i = 0; i < 7; i++)
+        sum += f.data[i];
+    sum += 0x70 + 0x03;
+    f.data[7] = static_cast<uint8_t>(sum & 0xFF);
+    return f;
+}
+
+// 0x318 GTW_carState — only byte 6 bits 1:0 matter for OTA gating.
+static CanFrame makeGtwCarState(uint8_t otaRaw)
+{
+    CanFrame f = {.id = 0x318, .dlc = 8};
+    f.data[6] = otaRaw & 0x03;
+    return f;
+}
+
+// 0x39B DAS_status — DAS_autopilotState (byte1 hi nibble) + handsOnState
+// (byte5 bits 5:2).
+static CanFrame makeDasStatus(uint8_t apState, uint8_t handsOnState)
+{
+    CanFrame f = {.id = 0x39B, .dlc = 8};
+    f.data[1] = static_cast<uint8_t>((apState & 0x0F) << 4);
+    f.data[5] = static_cast<uint8_t>((handsOnState & 0x0F) << 2);
+    return f;
+}
+
+static bool verifyEchoChecksum(const CanFrame &f)
+{
+    uint16_t sum = 0;
+    for (int i = 0; i < 7; i++)
+        sum += f.data[i];
+    sum += 0x70 + 0x03;
+    return f.data[7] == static_cast<uint8_t>(sum & 0xFF);
+}
+
+// handleMessage takes CanFrame& (non-const), so test call sites cannot pass
+// temporaries directly. This trampoline accepts by value and forwards as
+// lvalue, keeping the test bodies compact.
+static void deliver(CanFrame f) { handler.handleMessage(f, mock); }
+
+static int16_t decodeTorqueRaw(const CanFrame &f)
+{
+    return static_cast<int16_t>(((f.data[2] & 0x0F) << 8) | f.data[3]);
+}
+
+void setUp()
+{
+    mock.reset();
+    handler = FeatherHypery11Handler();
+    handler.enablePrint = false;
+    handler.seedPrng(0x12345678u);
+}
+void tearDown() {}
+
+// --- Filter IDs ---------------------------------------------------------
+
+void test_filter_ids_includes_required_frames()
+{
+    TEST_ASSERT_EQUAL_UINT8(3, handler.filterIdCount());
+    const uint32_t *ids = handler.filterIds();
+    bool has370 = false, has318 = false, has39b = false;
+    for (uint8_t i = 0; i < handler.filterIdCount(); i++)
+    {
+        if (ids[i] == 0x370) has370 = true;
+        if (ids[i] == 0x318) has318 = true;
+        if (ids[i] == 0x39B) has39b = true;
+    }
+    TEST_ASSERT_TRUE(has370);
+    TEST_ASSERT_TRUE(has318);
+    TEST_ASSERT_TRUE(has39b);
+}
+
+// --- 0x318 OTA gating ---------------------------------------------------
+
+void test_ota_raw_2_blocks_tx()
+{
+    CanFrame ota = makeGtwCarState(2);
+    handler.handleMessage(ota, mock);
+    TEST_ASSERT_TRUE(handler.otaInProgress);
+
+    // Seed DAS state so dasGate is not the reason for blocking.
+    CanFrame das = makeDasStatus(2, 2);
+    handler.handleMessage(das, mock);
+
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL_UINT32(1, handler.nagBlockedOta);
+}
+
+void test_ota_raw_0_does_not_set_in_progress()
+{
+    CanFrame ota = makeGtwCarState(0);
+    handler.handleMessage(ota, mock);
+    TEST_ASSERT_FALSE(handler.otaInProgress);
+}
+
+void test_ota_raw_1_does_not_set_in_progress()
+{
+    // "Available" must not block — historical false-positive (hypery11 #19).
+    CanFrame ota = makeGtwCarState(1);
+    handler.handleMessage(ota, mock);
+    TEST_ASSERT_FALSE(handler.otaInProgress);
+}
+
+void test_ota_raw_3_does_not_set_in_progress()
+{
+    CanFrame ota = makeGtwCarState(3);
+    handler.handleMessage(ota, mock);
+    TEST_ASSERT_FALSE(handler.otaInProgress);
+}
+
+void test_ota_clears_when_back_to_0()
+{
+    deliver(makeGtwCarState(2));
+    TEST_ASSERT_TRUE(handler.otaInProgress);
+    deliver(makeGtwCarState(0));
+    TEST_ASSERT_FALSE(handler.otaInProgress);
+}
+
+// --- 0x39B DAS parse ---------------------------------------------------
+
+void test_das_status_parses_ap_state()
+{
+    deliver(makeDasStatus(0x0A, 0x05));
+    TEST_ASSERT_EQUAL_UINT8(0x0A, handler.dasApState);
+}
+
+void test_das_status_parses_hands_on_state()
+{
+    deliver(makeDasStatus(0x02, 0x07));
+    TEST_ASSERT_EQUAL_UINT8(0x07, handler.dasHandsOnState);
+    TEST_ASSERT_TRUE(handler.dasSeen);
+}
+
+// --- 0x370 echo eligibility --------------------------------------------
+
+// Helper: drive DAS state into "echo allowed" territory (not 0, not 8).
+static void seedActiveDas()
+{
+    deliver(makeDasStatus(2, 2));
+}
+
+void test_epas_handson_0_produces_echo_when_active()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    TEST_ASSERT_EQUAL_UINT32(0x370, mock.sent[0].id);
+}
+
+void test_epas_handson_3_produces_echo_and_clears_level_to_1()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(3, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    uint8_t outLevel = (mock.sent[0].data[4] >> 6) & 0x03;
+    TEST_ASSERT_EQUAL_UINT8(1, outLevel);
+}
+
+void test_epas_handson_2_produces_echo()
+{
+    // Level 2 (warn) is not the skip level — should still echo.
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(2, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+}
+
+void test_epas_handson_1_produces_no_echo()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(1, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+}
+
+// --- DAS gate ----------------------------------------------------------
+
+void test_das_state_0_blocks_echo()
+{
+    deliver(makeDasStatus(2, 0));
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+}
+
+void test_das_state_8_blocks_echo()
+{
+    deliver(makeDasStatus(2, 8));
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+}
+
+void test_das_state_2_allows_echo()
+{
+    deliver(makeDasStatus(2, 2));
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+}
+
+void test_unseen_das_state_0xff_echoes_conservatively()
+{
+    // No 0x39B seen yet — dasHandsOnState stays 0xFF, gate must allow echo.
+    TEST_ASSERT_FALSE(handler.dasSeen);
+    TEST_ASSERT_EQUAL_UINT8(0xFF, handler.dasHandsOnState);
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+}
+
+void test_das_gate_disabled_overrides_block()
+{
+    deliver(makeDasStatus(2, 0));
+    handler.dasGate = false;
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+}
+
+// --- Listen-only gating ------------------------------------------------
+
+void test_listen_only_blocks_echo_via_driver_mode()
+{
+    seedActiveDas();
+    mock.setMode(CanMode::ListenOnly);
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL(0, mock.blocked.size()); // handler returned before send()
+    TEST_ASSERT_EQUAL_UINT32(1, handler.nagBlockedListenOnly);
+}
+
+// --- nagKillerActive toggle --------------------------------------------
+
+void test_nag_killer_disabled_blocks_echo()
+{
+    seedActiveDas();
+    handler.nagKillerActive = false;
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL_UINT32(0, handler.nagEchoCount);
+}
+
+// --- Counter wrap ------------------------------------------------------
+
+void test_counter_increments_by_1()
+{
+    seedActiveDas();
+    deliver(makeEpasFrame(0, 0x05));
+    uint8_t cnt = mock.sent[0].data[6] & 0x0F;
+    TEST_ASSERT_EQUAL_HEX8(0x06, cnt);
+}
+
+void test_counter_wraps_from_f_to_0()
+{
+    seedActiveDas();
+    deliver(makeEpasFrame(0, 0x0F));
+    uint8_t cnt = mock.sent[0].data[6] & 0x0F;
+    TEST_ASSERT_EQUAL_HEX8(0x00, cnt);
+}
+
+void test_counter_preserves_upper_nibble()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    epas.data[6] = (epas.data[6] & 0x0F) | 0xA0; // force upper = 0xA
+    // recompute input checksum
+    uint16_t sum = 0;
+    for (int i = 0; i < 7; i++)
+        sum += epas.data[i];
+    sum += 0x70 + 0x03;
+    epas.data[7] = static_cast<uint8_t>(sum);
+
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    uint8_t upper = mock.sent[0].data[6] & 0xF0;
+    TEST_ASSERT_EQUAL_HEX8(0xA0, upper);
+}
+
+// --- Output checksum ---------------------------------------------------
+
+void test_echo_checksum_is_correct()
+{
+    seedActiveDas();
+    deliver(makeEpasFrame(0, 0x05));
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    TEST_ASSERT_TRUE(verifyEchoChecksum(mock.sent[0]));
+}
+
+void test_echo_checksum_correct_across_counter_sweep()
+{
+    seedActiveDas();
+    for (uint8_t c = 0; c < 16; c++)
+    {
+        mock.reset();
+        handler.seedPrng(0x12345678u);
+        seedActiveDas();
+        deliver(makeEpasFrame(0, c));
+        TEST_ASSERT_EQUAL(1, mock.sent.size());
+        TEST_ASSERT_TRUE_MESSAGE(verifyEchoChecksum(mock.sent[0]),
+                                 "echo checksum failed on counter sweep");
+    }
+}
+
+// --- Organic torque range ---------------------------------------------
+
+void test_organic_torque_stays_in_planned_envelope()
+{
+    // With organicTorque on, every echoed torque must be inside the union
+    // of the walk band [kTorqueWalkMin, kTorqueWalkMax] and the pulse band
+    // [kTorquePulseMin, kTorquePulseMax].
+    seedActiveDas();
+    handler.organicTorque = true;
+    int seenWalk = 0, seenPulse = 0;
+    for (int i = 0; i < 500; i++)
+    {
+        CanFrame epas = makeEpasFrame(0, i & 0x0F);
+        handler.handleMessage(epas, mock);
+    }
+    TEST_ASSERT_EQUAL(500, mock.sent.size());
+    for (const auto &f : mock.sent)
+    {
+        int16_t torq = decodeTorqueRaw(f);
+        bool inWalk = (torq >= FeatherHypery11Handler::kTorqueWalkMin &&
+                       torq <= FeatherHypery11Handler::kTorqueWalkMax);
+        bool inPulse = (torq >= FeatherHypery11Handler::kTorquePulseMin &&
+                        torq <= FeatherHypery11Handler::kTorquePulseMax);
+        if (inWalk) seenWalk++;
+        if (inPulse) seenPulse++;
+        TEST_ASSERT_TRUE_MESSAGE(inWalk || inPulse,
+                                 "torque outside walk/pulse envelope");
+    }
+    // We expect both populations to appear in a 500-frame run.
+    TEST_ASSERT_TRUE(seenWalk > 0);
+    TEST_ASSERT_TRUE(seenPulse > 0);
+}
+
+void test_organic_torque_disabled_returns_fixed_value()
+{
+    seedActiveDas();
+    handler.organicTorque = false;
+    deliver(makeEpasFrame(0, 0x05));
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    int16_t torq = decodeTorqueRaw(mock.sent[0]);
+    TEST_ASSERT_EQUAL_INT16(FeatherHypery11Handler::kTorqueFixed, torq);
+}
+
+// --- Output shape ------------------------------------------------------
+
+void test_echo_id_is_0x370()
+{
+    seedActiveDas();
+    deliver(makeEpasFrame(0, 0x05));
+    TEST_ASSERT_EQUAL_UINT32(0x370, mock.sent[0].id);
+}
+
+void test_echo_dlc_is_8()
+{
+    seedActiveDas();
+    deliver(makeEpasFrame(0, 0x05));
+    TEST_ASSERT_EQUAL_UINT8(8, mock.sent[0].dlc);
+}
+
+void test_echo_preserves_bytes_0_1_5()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    epas.data[0] = 0xAB;
+    epas.data[1] = 0xCD;
+    epas.data[5] = 0x42;
+    uint16_t sum = 0;
+    for (int i = 0; i < 7; i++)
+        sum += epas.data[i];
+    sum += 0x70 + 0x03;
+    epas.data[7] = static_cast<uint8_t>(sum);
+
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(1, mock.sent.size());
+    TEST_ASSERT_EQUAL_HEX8(0xAB, mock.sent[0].data[0]);
+    TEST_ASSERT_EQUAL_HEX8(0xCD, mock.sent[0].data[1]);
+    TEST_ASSERT_EQUAL_HEX8(0x42, mock.sent[0].data[5]);
+}
+
+// --- Counters ----------------------------------------------------------
+
+void test_epas_seen_count_increments()
+{
+    CanFrame epas = makeEpasFrame(1, 0x05); // level 1 → no echo, still counts as seen
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL_UINT32(1, handler.epasSeenCount);
+    TEST_ASSERT_EQUAL_UINT32(0, handler.nagEchoCount);
+}
+
+void test_nag_echo_count_tracks_successful_echoes()
+{
+    seedActiveDas();
+    for (int i = 0; i < 4; i++)
+        deliver(makeEpasFrame(0, i));
+    TEST_ASSERT_EQUAL_UINT32(4, handler.nagEchoCount);
+    TEST_ASSERT_EQUAL_UINT32(4, handler.framesSent);
+}
+
+// --- Non-target frames ignored ----------------------------------------
+
+void test_unknown_id_is_ignored()
+{
+    CanFrame f = {.id = 0x123, .dlc = 8};
+    handler.handleMessage(f, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+    TEST_ASSERT_EQUAL_UINT32(0, handler.epasSeenCount);
+    TEST_ASSERT_FALSE(handler.otaInProgress);
+    TEST_ASSERT_FALSE(handler.dasSeen);
+}
+
+void test_short_epas_dlc_does_not_echo()
+{
+    seedActiveDas();
+    CanFrame epas = makeEpasFrame(0, 0x05);
+    epas.dlc = 7;
+    handler.handleMessage(epas, mock);
+    TEST_ASSERT_EQUAL(0, mock.sent.size());
+}
+
+int main()
+{
+    UNITY_BEGIN();
+
+    RUN_TEST(test_filter_ids_includes_required_frames);
+
+    RUN_TEST(test_ota_raw_2_blocks_tx);
+    RUN_TEST(test_ota_raw_0_does_not_set_in_progress);
+    RUN_TEST(test_ota_raw_1_does_not_set_in_progress);
+    RUN_TEST(test_ota_raw_3_does_not_set_in_progress);
+    RUN_TEST(test_ota_clears_when_back_to_0);
+
+    RUN_TEST(test_das_status_parses_ap_state);
+    RUN_TEST(test_das_status_parses_hands_on_state);
+
+    RUN_TEST(test_epas_handson_0_produces_echo_when_active);
+    RUN_TEST(test_epas_handson_3_produces_echo_and_clears_level_to_1);
+    RUN_TEST(test_epas_handson_2_produces_echo);
+    RUN_TEST(test_epas_handson_1_produces_no_echo);
+
+    RUN_TEST(test_das_state_0_blocks_echo);
+    RUN_TEST(test_das_state_8_blocks_echo);
+    RUN_TEST(test_das_state_2_allows_echo);
+    RUN_TEST(test_unseen_das_state_0xff_echoes_conservatively);
+    RUN_TEST(test_das_gate_disabled_overrides_block);
+
+    RUN_TEST(test_listen_only_blocks_echo_via_driver_mode);
+    RUN_TEST(test_nag_killer_disabled_blocks_echo);
+
+    RUN_TEST(test_counter_increments_by_1);
+    RUN_TEST(test_counter_wraps_from_f_to_0);
+    RUN_TEST(test_counter_preserves_upper_nibble);
+
+    RUN_TEST(test_echo_checksum_is_correct);
+    RUN_TEST(test_echo_checksum_correct_across_counter_sweep);
+
+    RUN_TEST(test_organic_torque_stays_in_planned_envelope);
+    RUN_TEST(test_organic_torque_disabled_returns_fixed_value);
+
+    RUN_TEST(test_echo_id_is_0x370);
+    RUN_TEST(test_echo_dlc_is_8);
+    RUN_TEST(test_echo_preserves_bytes_0_1_5);
+
+    RUN_TEST(test_epas_seen_count_increments);
+    RUN_TEST(test_nag_echo_count_tracks_successful_echoes);
+
+    RUN_TEST(test_unknown_id_is_ignored);
+    RUN_TEST(test_short_epas_dlc_does_not_echo);
+
+    return UNITY_END();
+}
